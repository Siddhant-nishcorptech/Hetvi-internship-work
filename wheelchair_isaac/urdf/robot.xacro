<?xml version="1.0" ?>
<robot name="robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="$(find wheelchair_isaac)/urdf/materials.xacro" />
<xacro:include filename="$(find wheelchair_isaac)/urdf/robot.trans" />
<xacro:include filename="$(find wheelchair_isaac)/urdf/robot.gazebo" />

<link name="base_footprint"/>

<link name="base_link">
  <inertial>
    <origin xyz="4.216737006355157e-05 0.14539775015650658 0.001317145519381857" rpy="0 0 0"/>
    <mass value="5.68537979998827"/>
    <inertia ixx="0.122934" iyy="0.179358" izz="0.285612" ixy="-3.1e-05" iyz="0.016444" ixz="6e-06"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find wheelchair_isaac)/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find wheelchair_isaac)/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<joint name="base_footprint_joint" type="fixed">
  <origin xyz="0 0 0.6" rpy="0 0 0"/>
  <parent link="base_footprint"/>
  <child link="base_link"/>
</joint>

<!-- IMU sensor link mounted at base_link center of mass -->
<link name="imu_link">
  <inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <mass value="0.01"/>
    <inertia ixx="1e-06" iyy="1e-06" izz="1e-06" ixy="0" iyz="0" ixz="0"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <box size="0.02 0.02 0.02"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <box size="0.02 0.02 0.02"/>
    </geometry>
  </collision>
</link>

<joint name="imu_joint" type="fixed">
  <origin xyz="0.0 0.145 0.001" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="imu_link"/>
</joint>

