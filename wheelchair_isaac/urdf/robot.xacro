<joint name="base_to_link1_left" type="revolute">
  <origin xyz="-0.269 0.0798 -0.054998" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="link_1_1"/>
  <axis xyz="-1.0 -0.0 -0.0"/>
  <limit lower="-1.5700" upper="0.0540" effort="100" velocity="1.0"/>
</joint>

<!-- link1_to_track_left joint REMOVED from URDF tree (creates kinematic loop). -->
<!-- This connection is closed in MuJoCo via <equality><connect> constraint. -->
<!-- Pin hole on link_1_1 (relative to link_1_1 frame): pos="0.045 -0.113272 -0.099807" -->

<joint name="wheel_left" type="continuous">
  <origin xyz="-0.06 0.691121 -0.155" rpy="0 0 0"/>
  <parent link="track_left_1"/>
  <child link="left_wheel_1"/>
  <axis xyz="-1.0 -0.0 -0.0"/>
</joint>

<joint name="base_to_link2_left" type="revolute">
  <origin xyz="-0.269 0.185 -0.179243" rpy="0 0 0"/>
